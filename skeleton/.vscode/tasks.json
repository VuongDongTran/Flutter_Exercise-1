{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Launch Android Emulator (Auto)",
            "type": "shell",
            "command": "emulator_id=$(flutter emulators | grep -o '[a-zA-Z0-9_-]*' | grep -v 'emulators' | head -1) && flutter emulators --launch $emulator_id && echo 'Waiting for emulator to boot...' && adb wait-for-device && while [ \"$(adb shell getprop sys.boot_completed 2>/dev/null | tr -d '\\r')\" != \"1\" ]; do sleep 1; done && sleep 5 && echo 'Emulator fully ready!'",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Launch Android Emulator (Select)",
            "type": "shell",
            "command": "flutter emulators --launch ${input:emulatorId}",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "List Android Emulators",
            "type": "shell",
            "command": "flutter emulators",
            "problemMatcher": [],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            }
        },
        {
            "label": "Flutter: Build Dev (Debug)",
            "type": "shell",
            "command": "flutter",
            "args": [
                "build",
                "apk",
                "--dart-define=ENVIRONMENT=dev",
                "--flavor=dev",
                "-v"
            ],
            "group": {
                "kind": "build",
