            "args": [
                "--dart-define=ENVIRONMENT=dev"
            ]
        },
        {
            "name": "Build Android APK (Release)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "build",
                "apk",
                "--release"
            ]
        },
        {
            "name": "Build Android App Bundle (Release)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "build",
                "appbundle",
                "--release"
            ]
        },
        {
            "name": "Build Android APK (Split per ABI)",
            "request": "launch",
            "type": "dart",
            "program": "lib/main.dart",
            "args": [
                "build",
                "apk",
                "--release",
                "--split-per-abi"
            ]
        }
