            "args": [
                "--flavor=uat",
                "--dart-define=ENVIRONMENT=uat"
            ]
        },
        {
            "name": "skeleton (UAT - iOS Debug Simulator)",
            "request": "launch",
            "type": "dart",
            "deviceId": "ios",
            "flutterMode": "debug",
            "args": [
                "--dart-define=ENVIRONMENT=uat"
            ]
        },
        {
            "name": "skeleton (Prod - Android Debug)",
            "request": "launch",
            "type": "dart",
