    "version": "0.2.0",
    "configurations": [
        {
            "name": "skeleton (Dev - Android Debug)",
            "request": "launch",
            "type": "dart",
            "deviceId": "android",
            "flutterMode": "debug",
            "args": [
                "--flavor=dev",
                "--dart-define=ENVIRONMENT=dev"
            ]
        },
        {
            "name": "skeleton (Dev - Android Auto Emulator)",
            "request": "launch",
            "type": "dart",
            "flutterMode": "debug",
            "preLaunchTask": "Launch Android Emulator (Auto)",
            "args": [
                "--flavor=dev",
                "--dart-define=ENVIRONMENT=dev"
            ]
        },
        {
            "name": "skeleton (Dev - iOS Debug Simulator)",
            "request": "launch",
            "type": "dart",
