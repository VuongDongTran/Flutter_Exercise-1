            "flutterMode": "debug",
            "args": [
                "--dart-define=ENVIRONMENT=prod"
            ]
        },
        {
            "name": "skeleton (Dev - Android Profile)",
            "request": "launch",
            "type": "dart",
            "deviceId": "android",
            "flutterMode": "profile",
            "args": [
                "--flavor=dev",
                "--dart-define=ENVIRONMENT=dev"
            ]
        },
        {
            "name": "skeleton (Dev - iOS Profile)",
            "request": "launch",
            "type": "dart",
